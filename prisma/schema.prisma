generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String        @id @default(cuid())
  username     String        @unique
  displayName  String?
  passwordHash String
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  sessions     Session[]
  activityLogs ActivityLog[]
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Person {
  id        String     @id @default(cuid())
  name      String
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  workItems WorkItem[]
}

model WorkArea {
  id          String     @id @default(cuid())
  name        String
  description String?
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  workItems   WorkItem[]
}

model WorkItem {
  id               String     @id @default(cuid())
  title            String
  description      String?
  status           Status     @default(todo)
  eta              DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  workAreaId       String
  assignedPersonId String?
  assignedPerson   Person?    @relation(fields: [assignedPersonId], references: [id])
  workArea         WorkArea   @relation(fields: [workAreaId], references: [id], onDelete: Restrict)
  comments         Comment[]
}

model Comment {
  id         String   @id @default(cuid())
  body       String
  authorName String?
  createdAt  DateTime @default(now())
  workItemId String
  workItem   WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id            String   @id @default(cuid())
  entityType    String
  entityId      String
  entityLabel   String
  action        String
  fieldName     String?
  oldValue      String?
  newValue      String?
  ipAddress     String
  actorUserId   String?
  actorUsername String?
  createdAt     DateTime @default(now())
  actorUser     User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
}

enum Status {
  todo
  in_progress
  blocked
  done
}
